# Import libraries
import pandas as pd
import matplotlib.pyplot as plt
from sklearn.linear_model import LinearRegression

# Create dataset
# House Size in square feet
size = [[500], [1000], [1500], [2000], [2500], [3000]]

# House Prices
price = [10, 20, 30, 40, 50, 60]

# Create model
model = LinearRegression()

# Train the model
model.fit(size, price)

# Predict price for a 3500 sq ft house
predicted_price = model.predict([[3500]])

# Print result
print("Predicted Price:", predicted_price[0], "lakhs")

# Plot graph
plt.scatter(size, price, color='blue')
plt.plot(size, model.predict(size), color='red')

plt.title('House Price Prediction')
plt.xlabel('House Size (sq ft)')
plt.ylabel('House Price (lakhs)')

plt.show()
